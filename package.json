{
  "name": "daily-briefing-bot",
  "version": "1.0.0",
  "description": "Automates daily tasks by collecting data from multiple sources, summarizing it with AI, and sending updates via Telegram.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "vitest": {
    "environment": "node",
    "include": ["tests/**/*.test.ts"],
    "coverage": {
      "provider": "v8",
      "include": ["src/**/*.ts"],
      "exclude": ["src/index.ts"]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alxmtzr/daily-briefing-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/alxmtzr/daily-briefing-bot/issues"
  },
  "homepage": "https://github.com/alxmtzr/daily-briefing-bot#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
