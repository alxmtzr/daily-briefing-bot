### Transport API (EFA-BW stop IDs)
TRANSPORT_STOP_1=your_stop_id_here           # Ravensburg Meersburger Brücke (primary morning stop)
TRANSPORT_STOP_ALTERNATIVE=your_stop_id_here  # Ravensburg Bahnhof (fallback)
TRANSPORT_STOP_2=your_stop_id_here           # Markdorf Gewerbegebiet (home stop)

### AI Provider
AI_API_KEY=your_gemini_api_key_here

### Notifier (Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

### Run context (set by GitHub Actions; override locally for testing)
RUN_LABEL=Morning

### Dev / testing flags
AI_ENABLED=true               # set to false to skip Gemini and print raw data instead
LOG_API_RESPONSES=false        # set to true to print each source's raw response to stdout
